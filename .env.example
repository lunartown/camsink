# Apple 개발자 계정 설정. 이 파일을 .env 로 복사해 채우세요.
# .env 는 저장소에 커밋되지 않습니다.

# Developer ID Application 인증서의 팀 ID
# 확인: security find-identity -v -p codesigning
TEAM_ID=XXXXXXXXXX

# App Store Connect API 키 (Admin 권한)
# 발급: https://appstoreconnect.apple.com/access/integrations/api
ASC_KEY_ID=XXXXXXXXXX
ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# .p8 키 파일 위치 (기본값: ~/.appstoreconnect/private_keys/AuthKey_<KEY_ID>.p8)
#ASC_KEY_PATH=

# 번들 식별자. 바꾸면 native/macos/ 안의 값들도 함께 바꿔야 합니다.
#BUNDLE_ID=com.lunartown.camsink
